# Copy to .env and fill in real values.

# Required
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_NOTIFY_URL=https://your-tunnel.example.com/api/payhere/notify

# Optional
